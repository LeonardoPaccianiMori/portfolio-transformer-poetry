  },
  "page_revisions": [
    {
      "title": "Spargi di lauri, palme e mirti foglie",
      "revision_id": 3760410,
      "revision_timestamp": "2026-04-25T22:38:51Z"
    },
    {
      "title": "Del funesto arbor l'ombre oscure e spesse",
      "revision_id": 3683235,
      "revision_timestamp": "2026-04-24T18:43:24Z"
    },
    {
      "title": "Famosi colli alteramente nati",
      "revision_id": 3690637,
      "revision_timestamp": "2026-04-24T20:38:08Z"
    },
    {
      "title": "Perché, s'io sguardo el sguardo ognor me rendi",
      "revision_id": 3742848,
      "revision_timestamp": "2026-04-25T18:04:05Z"
    },
    {
      "title": "Sonanti liti, e voi, rigidi scogli",
      "revision_id": 3759501,
      "revision_timestamp": "2026-04-25T22:25:28Z"
    },
    {
      "title": "Limpido fonte, che sovente ascolti",
      "revision_id": 3816879,
      "revision_timestamp": "2026-05-06T02:00:28Z"
    },
    {
      "title": "Or che a te el viver più diletta",
      "revision_id": 3736228,
      "revision_timestamp": "2026-04-25T14:02:07Z"
    },
    {
      "title": "Presago di sì rara e degna sòrte",
      "revision_id": 3746995,
      "revision_timestamp": "2026-04-25T19:19:11Z"
    },
    {
      "title": "Quand'i begli occhi suoi madonna e 'l volto",
      "revision_id": 3823636,
      "revision_timestamp": "2026-05-06T03:57:44Z"
    },
    {
      "title": "Ahi, belle membra, che coperte siete",
      "revision_id": 3794197,
      "revision_timestamp": "2026-05-05T18:56:37Z"
    },
    {
      "title": "Hai tolto agli occhi il suo beato obietto",
      "revision_id": 3804085,
      "revision_timestamp": "2026-05-05T22:03:56Z"
    },
    {
      "title": "Vogli, Padre del ciel, che l'alma torni",
      "revision_id": 3831376,
      "revision_timestamp": "2026-05-06T06:24:11Z"
    },
    {
      "title": "Giorni mal spesi e tempestose notti",
      "revision_id": 3695756,
      "revision_timestamp": "2026-04-24T21:46:15Z"
    },
    {
      "title": "Madonna, se la cieca e misera alma",
      "revision_id": 3817394,
      "revision_timestamp": "2026-05-06T02:09:19Z"
    },
    {
      "title": "False speranze ond'io predato fui",
      "revision_id": 3801693,
      "revision_timestamp": "2026-05-05T21:19:47Z"
    },
    {
      "title": "Felici sassi e reverende mura",
      "revision_id": 3691855,
      "revision_timestamp": "2026-04-24T20:53:44Z"
    },
    {
      "title": "Mirabil urna son, non d'opre tanto",
      "revision_id": 3818355,
      "revision_timestamp": "2026-05-06T02:27:01Z"
    },
    {
      "title": "Se ben, quando stavamo ai campi liete",
      "revision_id": 3758447,
      "revision_timestamp": "2026-04-25T22:09:45Z"
    },
    {
      "title": "Lasso, ch'io non so di chi biasmarmi",
      "revision_id": 3813705,
      "revision_timestamp": "2026-05-06T00:59:43Z"
    },
    {
      "title": "Gli occhi soavi ove 'l mio cor sospira",
      "revision_id": 3696495,
      "revision_timestamp": "2026-04-24T21:57:06Z"
    },
    {
      "title": "Il servo involto nel corporeo peso",
      "revision_id": 3808700,
      "revision_timestamp": "2026-05-05T23:26:28Z"
    }
  ],
